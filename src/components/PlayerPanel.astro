---
interface Props {
  index: 1 | 2;
  label: string;
}
const { index, label } = Astro.props;
const i = index;
---
<div class="player-panel" id={`player${i}`}>
  <div class="win-flash" id={`win${i}`}></div>
  <div class="victory-banner" id={`vb${i}`}>
    <div class="v-title">VICTORY</div>
    <div class="v-sub">Authority secured</div>
  </div>

  <div class="player-label" id={`label${i}`}>{label}</div>

  <div class="health-wrap">
    <div class="health-number" id={`hp${i}`}>50</div>
    <div class="pending-badge" id={`pending${i}`}></div>
  </div>

  <div class="controls-row">
    <div class="damage-controls">
      <button class="dmg-btn minus" id={`minus${i}`} aria-label="Decrease damage">−</button>
      <div class="dmg-display" id={`dmg${i}`}>0</div>
      <button class="dmg-btn" id={`plus${i}`} aria-label="Increase damage">+</button>
    </div>
    <div class="controls-divider"></div>
    <div class="heal-controls">
      <button class="dmg-btn heal-minus" id={`hminus${i}`} aria-label="Decrease heal">−</button>
      <div class="heal-display" id={`heal${i}`}>0</div>
      <button class="dmg-btn heal-plus" id={`hplus${i}`} aria-label="Increase heal">+</button>
    </div>
  </div>

  <button class="icon-btn undo-corner" id={`undo${i}`} title="Undo" disabled>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="9 14 4 9 9 4"/>
      <path d="M20 20v-7a4 4 0 0 0-4-4H4"/>
    </svg>
  </button>

  <div class="action-row">
    <button class="attack-btn" id={`attack${i}`} disabled>⚡ ATTACK</button>
    <div class="controls-divider"></div>
    <button class="heal-btn" id={`healBtn${i}`} disabled>✦ HEAL</button>
  </div>

  <div class="log-area" id={`log${i}`} role="button" tabindex="0" aria-label="Show full combat log"></div>

  <div class="log-overlay" id={`logOverlay${i}`}>
    <div class="log-overlay-header">
      <span class="log-overlay-title">COMBAT LOG</span>
      <button class="log-overlay-close" id={`logClose${i}`} aria-label="Close log">✕</button>
    </div>
    <div class="log-overlay-body" id={`logFull${i}`}></div>
  </div>
</div>
